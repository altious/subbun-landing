---
interface Props {
  name: string;
  price: string;
  cadence: string;
  description: string;
  features: string[];
  cta: string;
  ctaHref: string;
  featured?: boolean;
  badge?: string;
}

const {
  name, price, cadence, description, features, cta, ctaHref,
  featured = false, badge
} = Astro.props;
---

<div class={`relative rounded-2xl border ${featured ? "border-accent shadow-lg" : "border-gray-200"} bg-white p-6 flex flex-col`}>
  {badge && (
    <span class="absolute -top-3 right-6 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
      {badge}
    </span>
  )}
  <h3 class="text-lg font-bold mb-1">{name}</h3>
  <p class="text-sm text-ink-muted mb-4">{description}</p>
  <div class="flex items-baseline gap-1 mb-5">
    <span class="text-4xl font-extrabold">{price}</span>
    <span class="text-sm text-ink-muted">{cadence}</span>
  </div>
  <ul class="space-y-2 text-sm mb-6 flex-1">
    {features.map((f) => (
      <li class="flex gap-2 items-start">
        <span class="text-accent font-bold mt-0.5">✓</span>
        <span class="text-ink-muted">{f}</span>
      </li>
    ))}
  </ul>
  <a
    href={ctaHref}
    class={featured ? "btn-primary" : "btn-secondary"}
  >
    {cta}
  </a>
</div>
