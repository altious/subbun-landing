---
interface Props {
  q: string;
}
const { q } = Astro.props;
---

<details class="border-b border-gray-200 py-4 group">
  <summary class="cursor-pointer font-semibold list-none flex items-center justify-between gap-3">
    <span>{q}</span>
    <span class="text-accent transition-transform group-open:rotate-45 text-xl leading-none">+</span>
  </summary>
  <div class="mt-3 text-ink-muted leading-relaxed text-sm">
    <slot />
  </div>
</details>
