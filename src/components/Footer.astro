---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-100 bg-gray-50 mt-24">
  <div class="container-narrow py-10 grid gap-8 sm:grid-cols-4 text-sm">
    <div class="sm:col-span-2">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-accent text-white font-bold text-sm">あ</span>
        <span class="font-extrabold tracking-tight">Subbun</span>
      </div>
      <p class="text-ink-muted leading-relaxed max-w-md">
        Japanese subtitles and form-fill, in English. 100% on-device — your video and form content never leaves your computer.
      </p>
    </div>

    <div>
      <h3 class="font-semibold mb-3 text-ink">Product</h3>
      <ul class="space-y-2 text-ink-muted">
        <li><a href="/#video" class="hover:text-ink">Subbun for Video</a></li>
        <li><a href="/#forms" class="hover:text-ink">Subbun for Forms</a></li>
        <li><a href="/#pricing" class="hover:text-ink">Pricing</a></li>
        <li><a href="/help" class="hover:text-ink">Help / FAQ</a></li>
      </ul>
    </div>

    <div>
      <h3 class="font-semibold mb-3 text-ink">Legal</h3>
      <ul class="space-y-2 text-ink-muted">
        <li><a href="/privacy" class="hover:text-ink">Privacy</a></li>
        <li><a href="/terms" class="hover:text-ink">Terms</a></li>
        <li><a href="mailto:support@subbun.com" class="hover:text-ink">support@subbun.com</a></li>
      </ul>
    </div>
  </div>
  <div class="container-narrow py-4 border-t border-gray-200 text-xs text-ink-muted">
    © {year} Subbun. Not affiliated with YouTube, Netflix, Abema, Amazon, Niconico, Crunchyroll, TVer, NHK, U-NEXT, Disney, or Hulu.
  </div>
</footer>
